# API密钥配置 (不要提交到git!)
# 复制此文件为 api_keys.yaml 并填入真实密钥

# ==================== Kimi配置（推荐）====================
kimi:
  api_key: "YOUR_KIMI_API_KEY_HERE"  # Moonshot API Key
  model: "kimi-k2-5"                 # 模型选择
  base_url: "https://api.moonshot.cn/v1"  # API地址

# ==================== Claude配置（备选）====================
anthropic:
  api_key: "YOUR_ANTHROPIC_API_KEY_HERE"
  model: "claude-3-5-sonnet-20241022"

# 通用参数
max_tokens: 1024
temperature: 0.7

# ==================== B站直播配置 ====================
bilibili:
  room_id: 12345678  # 你的直播间ID
  sessdata: ""       # B站登录cookie (可选，用于获取真实弹幕)
  bili_jct: ""       # CSRF token (可选)

# ==================== TTS语音配置 ====================
tts:
  engine: "edge"  # 可选: "edge"(免费) 或 "gpt_sovits"(本地)
  
  # Edge TTS配置 (微软免费语音，开箱即用)
  edge_voice: "zh-CN-XiaoxiaoNeural"  # 晓晓，女声
  # 其他可选:
  # "zh-CN-YunxiNeural" - 云希，男声
  # "zh-CN-XiaoyiNeural" - 晓伊，女声
  # "zh-CN-YunjianNeural" - 云健，男声
  
  # GPT-SoVITS配置 (本地语音克隆，效果更好)
  gpt_sovits_url: "http://localhost:9880"  # 本地服务地址

# ==================== VTube Studio配置 ====================
vtube_studio:
  enabled: true
  ip: "127.0.0.1"
  port: 8001
  
  # 热键映射 (需在VTube Studio中设置对应快捷键)
  hotkeys:
    happy: "f1"        # 开心表情
    sad: "f2"          # 难过表情  
    surprised: "f3"    # 惊讶表情
    angry: "f4"        # 生气表情
    neutral: "f5"      # 默认表情
    laugh: "f6"        # 笑声动画
    wave: "f7"         # 挥手动画
    dance: "f8"        # 跳舞动画
